# /etc/hiworks-sync.env  (권한 600)
HIWORKS_ID=api@yourcompany.com
HIWORKS_PW=여기에_전용계정_비밀번호
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=hiworks_sync
MYSQL_PASSWORD=여기에_MySQL_비밀번호
MYSQL_DB=asterisk
COOKIE_FILE=/opt/hiworks/cookies.json
COOKIE_MAX_AGE=43200
PORT=8088
# 조직도(직원) 동기화 — Open API Bearer 토큰. 미설정이면 공유주소록만 동기화.
# 직원은 '이름 (부서)' 형식으로 CID 표시됨.
# HIWORKS_OFFICE_TOKEN=
# HIWORKS_ORG_API_URL=https://api.office.hiworks.com/hrm/v2/organizations
# 동기화 연속 실패 알림(n8n 웹훅). 미설정이면 알림 비활성.
# ALERT_WEBHOOK_URL=https://n8n.example.com/webhook/hiworks-sync
# ALERT_AFTER_FAILURES=3      # 연속 N회 실패부터 알림 (2분 주기면 ~6분)
# ALERT_REPEAT_EVERY=30       # 이후 N회마다 재알림 (스팸 방지, ~1시간)
# 수동 쿠키로 먼저 검증하려면 아래 주석을 풀고 브라우저 cookie 값을 붙여넣으세요
# HIWORKS_COOKIE=
